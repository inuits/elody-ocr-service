{
  "openapi": "3.0.3",
  "info": {
    "title": "Inuits DAMS ocr service API",
    "description": "An API to ocr images into txt, alto and pdf",
    "contact": {
      "email": "developers@inuits.eu"
    },
    "version": "0.0.1"
  },
  "externalDocs": {
    "description": "Find out more about DAMS",
    "url": "https://docs.inuits.io/dams/ocr-service"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/ocr": {
      "post": {
        "tags": [
          "ocr"
        ],
        "summary": "Ocr images into txt, alto or pdf in DAMS",
        "operationId": "startOcr",
        "parameters": [
          {
            "name": "language",
            "in": "query",
            "description": "Give the language in which the image should be ocred. Possible languages: ['eng', 'nld', 'fra']",
            "required": false,
            "schema": {
              "type": "string",
              "default": ""
            }
          }
        ],
        "requestBody": {
          "description": "Details needed to run an ocr job",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ocr"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ocr"
                }
              }
            }
          },
          "400": {
            "description": "malformed request body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ocr"
                }
              }
            }
          },
          "405": {
            "description": "invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ocr"
                }
              }
            }
          }
        }
      }
    },
    "/ocr/correction": {
      "post": {
        "tags": [
          "ocr"
        ],
        "summary": "Post a correction on the OCR txt output",
        "operationId": "doCorrection",
        "requestBody": {
          "description": "Details needed to make a OCR txt correction request",
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "mediafile_id": {
                    "type": "string",
                    "description": "mediafile id",
                    "format": "uuid"
                  },
                  "updated_text": {
                    "type": "string",
                    "description": "The full ocr text ouptut updated with corrections"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ocr_correction"
                }
              }
            }
          },
          "400": {
            "description": "bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ocr_correction"
                }
              }
            }
          }
        }
      }
    },
    "/status": {
      "get": {
        "tags": [
          "status"
        ],
        "summary": "Get status of tesseract & pytesseract",
        "operationId": "getStatus",
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "400": {
            "description": "something went wrong"
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Get health of ocr service",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "500": {
            "description": "internal server error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ocr": {
        "type": "object",
        "description": "Necessary ocr information",
        "required": [
          "type"
        ],
        "properties": {
          "mediafile_id": {
            "type": "array",
            "description": "mediafile id",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "operation": {
            "type": "string",
            "description": "operation: ['txt', 'alto', 'pdf']"
          }
        }
      },
      "ocr_correction": {
        "type": "object",
        "description": "Information to do an OCR txt correction request",
        "required": [
          "type"
        ],
        "properties": {
          "mediafile_id": {
            "type": "string",
            "description": "mediafile id",
            "format": "uuid"
          },
          "updated_text": {
            "type": "string",
            "description": "The full ocr text ouptut updated with corrections"
          }
        }
      }
    }
  }
}